<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>any2tidb.log</file>
        <append>true</append>
        <encoder>
            <pattern>[%d{yyyy/MM/dd HH:mm:ss.SSS Z}] [%level] %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="FILE" />
    </root>
</configuration>
