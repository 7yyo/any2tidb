<configuration>
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>a2t.log</file>
        <append>true</append>
        <encoder>
            <pattern>[%d{yyyy/MM/dd HH:mm:ss.SSS Z}] [%level] %msg%n</pattern>
        </encoder>
    </appender>
    <root level="OFF" />
    <logger name="com.tool" level="INFO" additivity="false">
        <appender-ref ref="FILE" />
    </logger>
</configuration>
